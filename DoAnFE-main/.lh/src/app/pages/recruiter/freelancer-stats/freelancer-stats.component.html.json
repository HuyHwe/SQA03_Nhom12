2 focus:ring-offset-2 focus:ring-indigo-500': !isLoading && !statsForm?.invalid,\r\n+          'bg-gray-400 cursor-not-allowed': isLoading || statsForm?.invalid\r\n+        }\">\r\n+        <span *ngIf=\"!isLoading\">Tìm kiếm Thống kê</span>\r\n+        <span *ngIf=\"isLoading\" class=\"flex items-center justify-center gap-2\">\r\n+          <svg class=\"animate-spin w-5 h-5 text-white\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\"\r\n+            viewBox=\"0 0 24 24\">\r\n+            <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\r\n+            <path class=\"opacity-75\" fill=\"currentColor\"\r\n+              d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\">\r\n+            </path>\r\n+          </svg>\r\n+          Đang tải...\r\n+        </span>\r\n+      </button>\r\n+    </form>\r\n+\r\n+    <!-- Error Message -->\r\n+    <div *ngIf=\"errorMessage\"\r\n+      class=\"bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-md shadow-md animate-pulse w-full max-w-7xl mx-auto\">\r\n+      <p class=\"font-bold\">Lỗi!</p>\r\n+      <p>{{ errorMessage }}</p>\r\n     </div>\r\n \r\n-    <div class=\"form-group\">\r\n-      <label for=\"topK\">Top K (default 10):</label>\r\n-      <input id=\"topK\" type=\"number\" formControlName=\"topK\" placeholder=\"10\" min=\"1\" max=\"50\">\r\n-      <div *ngIf=\"statsForm?.get('topK')?.invalid && statsForm?.get('topK')?.touched\" class=\"error-text\">\r\n-        Top K must be between 1 and 50.\r\n+    <!-- Stats Summary -->\r\n+    <div *ngIf=\"!isLoading && responseData.length > 0\" class=\"results-section w-full bg-white p-6 rounded-xl shadow-lg flex flex-col gap-6\">\r\n+      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n+        <div class=\"p-4 bg-indigo-50 rounded-lg border-l-4 border-indigo-600 shadow-sm\">\r\n+          <h4 class=\"text-sm font-medium text-gray-5