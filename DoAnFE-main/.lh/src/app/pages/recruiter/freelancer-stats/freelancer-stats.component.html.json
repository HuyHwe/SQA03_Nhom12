            "date": 1764226837690,
            "name": "Commit-0",
            "content": "<!-- freelancer-stats.component.html -->\r\n<!-- Template: Form to input params, loading spinner, stats display, and table for top freelancers -->\r\n\r\n<div class=\"freelancer-stats-container\">\r\n  <h2>Freelancer Stats by Job Default</h2>\r\n\r\n  <!-- Input Form -->\r\n  <form [formGroup]=\"statsForm\" (ngSubmit)=\"onSubmit()\" class=\"stats-form\">\r\n    <div class=\"form-group\">\r\n      <label for=\"recruiterId\">Recruiter ID:</label>\r\n      <input id=\"recruiterId\" type=\"number\" formControlName=\"recruiterId\" placeholder=\"Enter Recruiter ID\">\r\n    </div>\r\n\r\n    <div class=\"form-group\">\r\n      <label for=\"jobDefaultId\">Job Default ID:</label>\r\n      <input id=\"jobDefaultId\" type=\"number\" formControlName=\"jobDefaultId\" placeholder=\"Enter Job Default ID\">\r\n    </div>\r\n\r\n    <div class=\"form-group\">\r\n      <label for=\"topK\">Top K (default 10):</label>\r\n      <input id=\"topK\" type=\"number\" formControlName=\"topK\" placeholder=\"10\">\r\n    </div>\r\n\r\n    <button type=\"submit\" [disabled]=\"isLoading || statsForm.invalid\" class=\"submit-btn\">\r\n      {{ isLoading ? 'Loading...' : 'Fetch Stats' }}\r\n    </button>\r\n  </form>\r\n\r\n  <!-- Error Display -->\r\n  <div *ngIf=\"errorMessage\" class=\"error-message\">\r\n    {{ errorMessage }}\r\n  </div>\r\n\r\n  <!-- Results Display -->\r\n  <div *ngIf=\"responseData && !isLoading\" class=\"results-section\">\r\n    <div class=\"stats-summary\">\r\n      <h3>Summary</h3>\r\n      <p><strong>Total Suitable Freelancers:</strong> {{ responseData.totalSuitableCount }}</p>\r\n      <p><strong>Average Match Score:</strong> {{ scorePercentage }}% ({{ responseData.averageScore | number:'1.2-2' }})</p>\r\n    </div>\r\n\r\n    <!-- Top Freelancers Table -->\r\n    <div class=\"top-freelancers-table\" *ngIf=\"responseData.topFreelancers.length > 0\">\r\n      <h3>Top {{ responseData.topFreelancers.length }} Matching Freelancers</h3>\r\n      <table>\r\n        <thead>\r\n          <tr>\r\n            <th>ID</th>\r\n            <th>Name</th>\r\n            <th>Job</th>\r\n            <th>Experience Level</th>\r\n            <th>Skill Level</th>\r\n            <th>Match Score (%)</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody>\r\n          <tr *ngFor=\"let match of responseData.topFreelancers; let i = index\">\r\n            <td>{{ match.freelancer.id }}</td>\r\n            <td>{{ match.freelancer.name }}</td>\r\n            <td>{{ match.freelancer.job }}</td>\r\n            <td>{{ match.freelancer.experienceLevel }}</td>\r\n            <td>{{ match.freelancer.skillLevel }}</td>\r\n            <td>{{ (match.score * 100) | number:'1.1-1' }}%</td>\r\n          </tr>\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n\r\n    <div *ngIf=\"responseData.topFreelancers.length === 0\" class=\"no-data\">\r\n      <p>No suitable freelancers found.</p>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Loading Spinner -->\r\n  <div *ngIf=\"isLoading\" class=\"loading-spinner\">\r\n    <p>Loading stats...</p>\r\n    <!-- Add spinner element here, e.g., <mat-spinner> if using Angular Material -->\r\n  </div>\r\n</div>"
        }
    ]
}