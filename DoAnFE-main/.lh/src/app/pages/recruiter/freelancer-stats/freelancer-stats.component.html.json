reelancer.similarityScore ?? 0) * 100 | number:'1.1-1' }}%</td>\r\n+              <td class=\"px-3 py-4 text-xs\">{{ (freelancer.gnnScore ?? 0) * 100 | number:'1.1-1' }}%</td>\r\n+              <td class=\"px-3 py-4 text-xs\">{{ (freelancer.behaviorBoost ?? 0) * 100 | number:'1.1-1' }}%</td>\r\n+              <td class=\"px-3 py-4 text-xs\">{{ (freelancer.cvMatchScore ?? 0)  | number:'1.1-1' }}%</td>\r\n+              <td class=\"px-3 py-4\">\r\n+                <img *ngIf=\"freelancer.avatar\" [src]=\"freelancer.avatar\" alt=\"Avatar\" class=\"h-10 w-10 rounded-full object-cover border-2 border-indigo-200\">\r\n+                <span *ngIf=\"!freelancer.avatar\" class=\"text-xs text-gray-400\">N/A</span>\r\n+              </td>\r\n+              <td class=\"px-3 py-4\">\r\n+                <button (click)=\"openPopupInfoCandidate(freelancer); $event.stopPropagation()\"\r\n+                  class=\"bg-indigo-100 hover:bg-indigo-200 text-indigo-600 hover:text-indigo-900 p-2 rounded-lg text-xs font-semibold transition\">\r\n+                  Xem Chi tiết\r\n+                </button>\r\n+              </td>\r\n+            </tr>\r\n+          </tbody>\r\n+        </table>\r\n+      </div>\r\n     </div>\r\n \r\n-    <!-- Top Freelancers Table -->\r\n-    <div class=\"top-freelancers-table\" *ngIf=\"responseData && responseData.topFreelancers.length > 0\">\r\n-      <h3>Top {{ responseData?.topFreelancers?.length }} Matching Freelancers</h3>\r\n-      <table>\r\n-        <thead>\r\n-          <tr>\r\n-            <th>ID</th>\r\n-            <th>Name</th>\r\n-            <th>Job</th>\r\n-            <th>Experience Level</th>\r\n-            <th>Skill Level</th>\r\n-            <th>Match Score (%)</th>\r\n-            <th>Phone</th>\r\n-            <th>Email</th>\r\n-            <th>Province</th>\r\n-            <th>Salary</th>\r\n-            <th>CV</th>\r\n-          </tr>\r\n-        </thead>\r\n-        <tbody>\r\n-          <tr *ngFor=\"let match of responseData?.