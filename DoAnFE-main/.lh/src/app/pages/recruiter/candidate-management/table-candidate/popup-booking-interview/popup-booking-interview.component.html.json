            "date": 1767630382749,
            "name": "Commit-0",
            "content": "<div class=\"popup-container\" id=\"popup-booking\">\r\n  <div class=\"modal fixed inset-0 z-50 bg-black/50 backdrop-blur-sm\">\r\n    \r\n    <div *ngIf=\"methodInterview == 1\"\r\n      class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 md:w-[50%] w-[95%] max-h-[90vh] flex flex-col gap-0 rounded-xl overflow-hidden shadow-2xl bg-white\">\r\n      \r\n      <div class=\"flex px-5 py-4 items-center justify-between bg-[#00b14f]\">\r\n        <button (click)=\"onInterview(-1)\" class=\"hover:bg-white/20 p-1 rounded-full transition-all\">\r\n          <img src=\"../../../../../../assets/icons/arrow-left.svg\" alt=\"back\" class=\"brightness-0 invert\">\r\n        </button>\r\n        <h2 class=\"text-white font-bold text-lg uppercase tracking-wide\">\r\n          {{ \"bookInterviewLbl\" | translate }}\r\n        </h2>\r\n        <button (click)=\"closePopup()\" class=\"hover:bg-white/20 p-1 rounded-full transition-all\">\r\n          <img src=\"../../../../../../assets/icons/close.svg\" alt=\"close\" class=\"brightness-0 invert\">\r\n        </button>\r\n      </div>\r\n\r\n      <div class=\"flex flex-col p-6 gap-6 overflow-y-auto\">\r\n        <form [formGroup]=\"scheduleForm\" class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n          \r\n          <div class=\"flex flex-col gap-1 md:col-span-2\">\r\n            <label class=\"text-sm font-bold text-gray-700\">{{ \"topicLbl\" | translate }}</label>\r\n            <input formControlName=\"topic\" [(ngModel)]=\"schedule.topic\"\r\n              class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] focus:border-transparent outline-none transition-all\" \r\n              type=\"text\" placeholder=\"Nhập chủ đề phỏng vấn...\">\r\n          </div>\r\n\r\n          <div class=\"flex flex-col gap-1 md:col-span-2\">\r\n            <label class=\"text-sm font-bold text-gray-700\">{{ \"desJobLbl\" | translate }}</label>\r\n            <input formControlName=\"des\" [(ngModel)]=\"schedule.des\"\r\n              class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none\" \r\n              type=\"text\">\r\n          </div>\r\n\r\n          <div class=\"flex flex-col gap-1\">\r\n            <label class=\"text-sm font-bold text-gray-700\">{{ \"interviewDate\" | translate }}</label>\r\n            <input formControlName=\"interviewDate\" [(ngModel)]=\"schedule.interviewDate\"\r\n              class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none\" \r\n              type=\"date\">\r\n          </div>\r\n\r\n          <div class=\"flex gap-2 items-end\">\r\n            <div class=\"flex-1\">\r\n              <label class=\"text-xs font-bold text-gray-500\">{{ \"fromLbl\" | translate }}</label>\r\n              <input formControlName=\"interviewStartTime\" [(ngModel)]=\"schedule.interviewStartTime\"\r\n                class=\"w-full border border-gray-300 rounded-lg px-2 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none text-sm\" type=\"time\">\r\n            </div>\r\n            <div class=\"flex-1\">\r\n              <label class=\"text-xs font-bold text-gray-500\">{{ \"toLbl\" | translate }}</label>\r\n              <input formControlName=\"interviewEndTime\" [(ngModel)]=\"schedule.interviewEndTime\"\r\n                class=\"w-full border border-gray-300 rounded-lg px-2 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none text-sm\" type=\"time\">\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"md:col-span-2 py-2 px-3 bg-green-50 rounded-lg border border-green-100\">\r\n            <app-radio-button [items]=\"radioItems\" (radioOnChecked)=\"radioOnChecked($event)\"></app-radio-button>\r\n          </div>\r\n\r\n          <ng-container *ngIf=\"isChoseOnline()\">\r\n            <div class=\"flex flex-col gap-1\">\r\n              <label class=\"text-sm font-bold text-gray-700\">Meeting ID</label>\r\n              <input formControlName=\"meetingId\" [(ngModel)]=\"schedule.meetingId\"\r\n                class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none\" type=\"text\" placeholder=\"123 456 789\">\r\n            </div>\r\n            <div class=\"flex flex-col gap-1\">\r\n              <label class=\"text-sm font-bold text-gray-700\">Passcode</label>\r\n              <input formControlName=\"passcode\" [(ngModel)]=\"schedule.passcode\"\r\n                class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none\" type=\"text\" placeholder=\"******\">\r\n            </div>\r\n            <div class=\"flex flex-col gap-1 md:col-span-2\">\r\n              <label class=\"text-sm font-bold text-gray-700\">Link Zoom/Meet</label>\r\n              <input formControlName=\"linkzoom\" [(ngModel)]=\"schedule.linkzoom\"\r\n                class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none\" type=\"text\" placeholder=\"https://zoom.us/j/...\">\r\n            </div>\r\n          </ng-container>\r\n\r\n          <div *ngIf=\"!isChoseOnline()\" class=\"flex flex-col gap-1 md:col-span-2\">\r\n            <label class=\"text-sm font-bold text-gray-700\">{{ \"addressLbl\" | translate }}</label>\r\n            <input formControlName=\"address\" [(ngModel)]=\"schedule.address\"\r\n              class=\"border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-[#00b14f] outline-none\" \r\n              type=\"text\" placeholder=\"Địa điểm phỏng vấn trực tiếp...\">\r\n          </div>\r\n        </form>\r\n      </div>\r\n\r\n      <div class=\"flex justify-end items-center gap-3 p-5 bg-gray-50\">\r\n        <button (click)=\"closePopup()\" \r\n          class=\"px-6 py-2.5 rounded-lg font-semibold text-gray-600 hover:bg-gray-200 transition-all text-sm\">\r\n          {{ \"cancelLbl\" | translate }}\r\n        </button>\r\n        <button (click)=\"onInterview(2)\"\r\n          class=\"px-6 py-2.5 rounded-lg font-semibold text-white bg-[#00b14f] hover:bg-[#008e3f] shadow-lg shadow-green-200 transition-all text-sm\">\r\n          {{ \"createInterviewLbl\" | translate }}\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div *ngIf=\"methodInterview === 3\"\r\n      class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 md:w-[40%] w-[95%] flex flex-col rounded-xl overflow-hidden shadow-2xl bg-white\">\r\n      \r\n      <div class=\"flex px-5 py-4 items-center justify-between bg-[#00b14f]\">\r\n        <button (click)=\"onInterview(1)\"><img src=\"../../../../../../assets/icons/arrow-left.svg\" class=\"brightness-0 invert\"></button>\r\n        <h2 class=\"text-white font-bold text-lg uppercase\">{{ \"detailInterviewLbl\" | translate }}</h2>\r\n        <button (click)=\"closePopup()\"><img src=\"../../../../../../assets/icons/close.svg\" class=\"brightness-0 invert\"></button>\r\n      </div>\r\n\r\n      <div class=\"p-6 flex flex-col gap-6\">\r\n        <div class=\"flex items-center gap-8 py-3 px-4 bg-green-50 rounded-lg border border-green-100\">\r\n          <div class=\"flex items-center gap-2 cursor-pointer\">\r\n            <input id=\"effort\" type=\"radio\" value=\"effort\" name=\"result\" class=\"w-4 h-4 text-[#00b14f] focus:ring-[#00b14f]\">\r\n            <label for=\"effort\" class=\"text-sm font-bold text-gray-700\">{{ \"effortLbl\" | translate }}</label>\r\n          </div>\r\n          <div class=\"flex items-center gap-2 cursor-pointer\">\r\n            <input id=\"noteffort\" type=\"radio\" value=\"noteffort\" name=\"result\" class=\"w-4 h-4 text-[#00b14f] focus:ring-[#00b14f]\">\r\n            <label for=\"noteffort\" class=\"text-sm font-bold text-gray-700\">{{ \"noteffortLbl\" | translate }}</label>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"flex flex-col gap-2\">\r\n          <label class=\"text-sm font-bold text-gray-700\">Feedback</label>\r\n          <textarea rows=\"4\" class=\"w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-[#00b14f] outline-none\" \r\n            placeholder=\"Nhập nhận xét về ứng viên...\"></textarea>\r\n        </div>\r\n\r\n        <button class=\"w-full py-3 bg-[#00b14f] hover:bg-[#008e3f] text-white font-bold rounded-lg transition-all shadow-lg shadow-green-100\">\r\n          {{ \"sendresultInterviewLbl\" | translate }}\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n</div>"
        }
    ]
}