            "date": 1767666392982,
            "name": "Commit-0",
            "content": "<div class=\"popup-container\" id=\"popup-interview-detail\">\r\n\t<div class=\"modal\">\r\n\t\t<div class=\"modal-inner center-pos\">\r\n\t\t\t<div class=\"p-3 bg-blue rounded-top d-flex justify-content-between align-items-center position-relative\">\r\n\t\t\t\t<span class=\"font-size-big font-weight-bold global-text-color-white\">Chi tiết lịch phỏng vấn</span>\r\n\t\t\t\t<img type=\"button\" (click)=\"closePopup()\" src=\"../../../../../../assets/icons/white-close.svg\"\r\n\t\t\t\t\tclass=\"position-absolute top-0 end-0 p-3 cursor-pointer\" style=\"cursor: pointer;\">\r\n\t\t\t</div>\r\n\t\t\t<div class=\"p-4\" *ngIf=\"!loading && scheduleData\">\r\n\t\t\t\t<div class=\"popup-content w-full\">\r\n\t\t\t\t\t<div class=\"flex flex-col gap-4\">\r\n\t\t\t\t\t\t<!-- Topic -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">Topic</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\">{{ scheduleData.topic || \"Phỏng vấn\" }}</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Description -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">{{ \"desJobLbl\" | translate }}</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\">{{ scheduleData.des || scheduleData.jobName || \"\" }}</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Interview Time -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">Thời gian phỏng vấn</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\" *ngIf=\"scheduleData.startDate && scheduleData.endDate\">\r\n\t\t\t\t\t\t\t\t{{ getFormattedDate(scheduleData.startDate) }}, từ {{ getFormattedTime(scheduleData.startDate) }} đến {{ getFormattedTime(scheduleData.endDate) }}\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\" *ngIf=\"!scheduleData.startDate || !scheduleData.endDate\">\r\n\t\t\t\t\t\t\t\tChưa được thiết lập\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Interview Format -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">Hình thức phỏng vấn</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\">{{ getInterviewMethod() }}</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Location -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\" *ngIf=\"scheduleData.province || scheduleData.ward\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">{{ \"addressLbl\" | translate }}</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\">{{ getAddress() }}</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Meeting ID -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\" *ngIf=\"scheduleData.meetId\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">Meeting ID</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\">{{ scheduleData.meetId }}</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Passcode -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\" *ngIf=\"scheduleData.passcode\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">Passcode</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base\">{{ scheduleData.passcode }}</div>\r\n\t\t\t\t\t\t</div>\r\n\r\n\t\t\t\t\t\t<!-- Zoom Link -->\r\n\t\t\t\t\t\t<div class=\"flex flex-col gap-2\" *ngIf=\"scheduleData.meetUrl\">\r\n\t\t\t\t\t\t\t<div class=\"text-base font-semibold\" style=\"color: var(--ink);\">Link zoom</div>\r\n\t\t\t\t\t\t\t<div class=\"text-base break-all\" style=\"color: #3276FA; text-decoration: underline; cursor: pointer;\" (click)=\"onStart()\">\r\n\t\t\t\t\t\t\t\t{{ scheduleData.meetUrl }}\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"p-4 d-flex justify-content-center\" *ngIf=\"loading\">\r\n\t\t\t\t<div class=\"spinner-border\" role=\"status\">\r\n\t\t\t\t\t<span class=\"sr-only\">Đang tải...</span>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"col-12 py-4 horizontal-center-pos\" *ngIf=\"!loading && scheduleData\">\r\n\t\t\t\t<div class=\"col-md-12 right-btn-wrapper horizontal-center-pos vertical-center-pos-1\">\r\n\t\t\t\t\t<button class=\"btn border-none font-size-small font-weight-bold global-text-color-white bg-blue px-5\" \r\n\t\t\t\t\t\t(click)=\"onStart()\" *ngIf=\"scheduleData.startDate\">\r\n\t\t\t\t\t\tBắt đầu\r\n\t\t\t\t\t</button>\r\n\t\t\t\t\t<button class=\"btn border-none font-size-small font-weight-bold color-disable-text bg-disable px-5\" \r\n\t\t\t\t\t\t(click)=\"closePopup()\">\r\n\t\t\t\t\t\t{{ \"close\" | translate }}\r\n\t\t\t\t\t</button>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n</div>\r\n\r\n<app-popup-interview-result #popupInterviewResult></app-popup-interview-result>\r\n\r\n"
        }
    ]
}