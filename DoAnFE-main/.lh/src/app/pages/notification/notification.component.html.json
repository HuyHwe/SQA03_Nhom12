ex items-start space-x-4\">\r\n+        <!-- Biểu tượng thông báo -->\r\n+        <div class=\"flex-shrink-0\">\r\n+          <i class=\"fas fa-bell text-blue-500 text-lg\" [ngClass]=\"{'text-gray-400': notification.status === 'READ'}\"></i>\r\n         </div>\r\n-        <button\r\n-          *ngIf=\"notification.status === 'UNREAD'\"\r\n-          (click)=\"markAsRead(notification.id)\"\r\n-          class=\"text-xs text-blue-600 hover:underline\">\r\n-          {{ 'markAsRead' | translate }}\r\n-        </button>\r\n+        <!-- Nội dung thông báo -->\r\n+        <div class=\"flex-1\">\r\n+          <div class=\"flex justify-between items-start\">\r\n+            <div>\r\n+              <p class=\"text-lg font-semibold text-gray-800\">{{ notification.title }}</p>\r\n+              <p class=\"text-gray-600 mt-1\">{{ notification.message }}</p>\r\n+              <p class=\"text-xs text-gray-400 mt-2\">{{ notification.createdAt | date:'medium' }}</p>\r\n+            </div>\r\n+            <!-- Nút Mark as Read -->\r\n+            <button\r\n+              *ngIf=\"notification.status === 'UNREAD'\"\r\n+              (click)=\"markAsRead(notification.id)\"\r\n+              class=\"flex items-center text-xs text-blue-600 hover:text-blue-800 hover:underline transition-colors duration-200\">\r\n+              <i class=\"fas fa-check-circle mr-1\"></i>\r\n+              {{ 'markAsRead' | translate }}\r\n+            </button>\r\n+          </div>\r\n+        </div>\r\n       </div>\r\n-    \r\n     </div>\r\n   </div>\r\n </div>\n\\ No newline at end of file\n"
