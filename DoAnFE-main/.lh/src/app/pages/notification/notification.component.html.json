            "date": 1754982573052,
            "name": "Commit-0",
            "content": "<div class=\"container mx-auto p-4\">\r\n  <h2 class=\"text-2xl font-bold mb-4\">{{ 'notifications' | translate }}</h2>\r\n  <div *ngIf=\"notifications.length === 0\" class=\"text-gray-500\">\r\n    {{ 'noNotifications' | translate }}\r\n  </div>\r\n  <div class=\"space-y-4\">\r\n    <div *ngFor=\"let notification of notifications\" class=\"p-4 border rounded-md\" [ngClass]=\"{'bg-gray-100': notification.status === 'UNREAD'}\">\r\n      <div class=\"flex justify-between items-center\">\r\n        <div>\r\n          <p class=\"font-semibold\">{{ notification.title }}</p>\r\n          <p class=\"text-gray-600\">{{ notification.message }}</p>\r\n          <p class=\"text-xs text-gray-400\">{{ notification.createdAt | date:'short' }}</p>\r\n        </div>\r\n        <button\r\n          *ngIf=\"notification.status === 'UNREAD'\"\r\n          (click)=\"markAsRead(notification.id)\"\r\n          class=\"text-xs text-blue-600 hover:underline\">\r\n          {{ 'markAsRead' | translate }}\r\n        </button>\r\n      </div>\r\n      <a\r\n        *ngIf=\"notification.actionUrl\"\r\n        [href]=\"notification.actionUrl\"\r\n        (click)=\"navigateToActionUrl(notification.actionUrl)\"\r\n        class=\"text-blue-600 hover:underline text-xs\">\r\n        {{ 'viewDetails' | translate }}\r\n      </a>\r\n    </div>\r\n  </div>\r\n</div>"
