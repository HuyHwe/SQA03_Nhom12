            "content": "<div class=\"calendar-layout flex flex-col h-screen p-6 bg-[#f0f2f5]\">\r\n    <div class=\"flex items-center justify-between mb-6\">\r\n        <h1 class=\"text-3xl font-extrabold text-[#1a1f36] tracking-tight\">\r\n            {{ \"calendarLbl\" | translate }}\r\n        </h1>\r\n        \r\n        <form [formGroup]=\"dateForm\" class=\"flex items-center gap-4 bg-white p-2 rounded-2xl shadow-sm border border-gray-100\">\r\n            <div class=\"flex flex-col px-3 border-r border-gray-100\">\r\n                <span class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\">{{ \"startDate\" | translate }}</span>\r\n                <input \r\n                    type=\"date\" \r\n                    formControlName=\"startDate\"\r\n                    [(ngModel)]=\"startDate\"\r\n                    (change)=\"onChoseStartDate(startDate)\"\r\n                    class=\"text-sm font-semibold outline-none bg-transparent cursor-pointer\"\r\n                />\r\n            </div>\r\n            <button type=\"button\" (click)=\"onSearch()\" \r\n                class=\"px-6 py-2.5 bg-[#00b14f] text-white font-bold rounded-xl hover:bg-[#008e3f] transition-all hover:shadow-lg active:scale-95\">\r\n                {{ \"search\" | translate }}\r\n            </button>\r\n        </form>\r\n    </div>\r\n\r\n    <div class=\"flex-grow bg-white rounded-3xl shadow-xl border border-gray-200 overflow-hidden relative\">\r\n        <full-calendar #fullCalendar [options]=\"calendarOptions\"></full-calendar>\r\n    </div>\r\n</div>\r\n\r\n<app-popup-calendar-item #popupCalendarItemComponent></app-popup-calendar-item>"
