            "date": 1756105445906,
            "name": "Commit-0",
            "content": "<div class=\"flex justify-center p-3 w-full md:w-auto\">\r\n  <div *ngIf=\"loading\" class=\"text-center py-5\">Đang tải...</div>\r\n  <div *ngIf=\"!loading\" class=\"grid grid-cols-2 sm:grid-cols-5 gap-6 py-5 px-4 sm:px-6 rounded-xl bg-white w-full max-w-[1200px] mx-auto justify-center\" style=\"min-height: 500px;\">\r\n    <div (click)=\"gotoOtherPage(item)\"\r\n         class=\"item flex flex-col cursor-pointer items-center px-6 py-3 gap-2 rounded-md bg-white transition-all duration-200 hover:bg-[var(--light-pink)] hover:shadow-md hover:border-blue-500 h-[200px] w-full overflow-hidden\"\r\n         style=\"border: 1px solid var(--orange-orange-300);\" *ngFor=\"let item of displayed\">\r\n      <div class=\"flex justify-center items-center p-2 rounded-full h-20 w-full\" style=\"background: var(--light-pink);\">\r\n        <img [src]=\"item.icon || resolveIcon(item.name)\" [alt]=\"item.name\" class=\"w-16 h-16\" (error)=\"onImgError($event)\" />\r\n      </div>\r\n      <span class=\"font-body font-semibold text-base text-center not-italic item-title\" style=\"color: var(--orange);\">{{ item.name }}</span>\r\n    </div>\r\n    \r\n    <!-- Placeholder items to maintain grid layout when less than 10 items -->\r\n    <div class=\"item-placeholder h-[200px] w-full\" *ngFor=\"let placeholder of getPlaceholderCount()\"></div>\r\n  </div>\r\n</div>\r\n\r\n<!-- Nút điều hướng -->\r\n<div class=\"flex justify-center gap-4 mt-4\">\r\n  <button (click)=\"prev()\" class=\"px-4 py-2    text-white rounded\" [disabled]=\"page <= 0 || loading\">Previous</button>\r\n  <button (click)=\"next()\" class=\"px-4 py-2    text-white rounded\" [disabled]=\"page >= totalPage - 1 || loading\">Next</button>\r\n</div>"
        }
