            "date": 1757304937908,
            "name": "Commit-0",
            "content": "<div class=\"min-h-screen bg-gray-100\">\r\n  <div class=\"container mx-auto px-4 py-8\">\r\n    <!-- Thanh tìm kiếm -->\r\n    <div class=\"search-wrapper bg-white p-6 rounded-lg shadow-lg mb-8\">\r\n      <form [formGroup]=\"searchForm\" (ngSubmit)=\"onSearch()\">\r\n        <div class=\"flex flex-col md:flex-row gap-4 items-center\">\r\n          <!-- Ô nhập từ khóa -->\r\n          <div class=\"flex-1\">\r\n            <input\r\n              type=\"text\"\r\n              formControlName=\"searchKey\"\r\n              placeholder=\"Nhập từ khóa tìm kiếm (VD: sale)\"\r\n              class=\"w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500\"\r\n            />\r\n          </div>\r\n          <!-- Dropdown tỉnh/thành phố -->\r\n          <div class=\"w-full md:w-48\">\r\n            <app-selection-menu\r\n              [selectedItem]=\"selectedProvince\"\r\n              [items]=\"provinces\"\r\n              (onChangeSelected)=\"onProvinceSelected($event)\"\r\n              class=\"block w-full p-3\"\r\n            ></app-selection-menu>\r\n          </div>\r\n          <!-- Nút tìm kiếm -->\r\n          <button\r\n            type=\"submit\"\r\n            class=\"bg-blue-600 text-white px-6 py-3 rounded-lg flex items-center gap-2 hover:bg-blue-700\"\r\n          >\r\n            <svg\r\n              aria-hidden=\"true\"\r\n              class=\"w-5 h-5\"\r\n              fill=\"none\"\r\n              stroke=\"currentColor\"\r\n              viewBox=\"0 0 24 24\"\r\n              xmlns=\"http://www.w3.org/2000/svg\"\r\n            >\r\n              <path\r\n                stroke-linecap=\"round\"\r\n                stroke-linejoin=\"round\"\r\n                stroke-width=\"2\"\r\n                d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"\r\n              ></path>\r\n            </svg>\r\n            Tìm kiếm\r\n          </button>\r\n        </div>\r\n      </form>\r\n    </div>\r\n\r\n    <!-- Bộ lọc -->\r\n    <div class=\"filters-wrapper bg-white p-6 rounded-lg shadow-lg mb-8\">\r\n      <h2 class=\"text-xl font-bold mb-4\">Bộ lọc tìm kiếm</h2>\r\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n        <!-- Lương -->\r\n        <div>\r\n          <label class=\"flex items-center gap-2\">\r\n            <input type=\"checkbox\" [(ngModel)]=\"filterSalary\" class=\"h-5 w-5\" />\r\n            Lọc theo lương\r\n          </label>\r\n          <div *ngIf=\"filterSalary\" class=\"mt-2\">\r\n            <input\r\n              type=\"number\"\r\n              [(ngModel)]=\"minSalary\"\r\n              placeholder=\"Lương tối thiểu (triệu)\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-lg\"\r\n            />\r\n            <input\r\n              type=\"number\"\r\n              [(ngModel)]=\"maxSalary\"\r\n              placeholder=\"Lương tối đa (triệu)\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-lg mt-2\"\r\n            />\r\n          </div>\r\n        </div>\r\n        <!-- Ngành nghề -->\r\n        <div>\r\n          <label class=\"flex items-center gap-2\">\r\n            <input type=\"checkbox\" [(ngModel)]=\"filterJobDefault\" class=\"h-5 w-5\" />\r\n            Lọc theo ngành nghề\r\n          </label>\r\n          <div *ngIf=\"filterJobDefault\" class=\"mt-2\">\r\n            <app-selection\r\n              [selectedItem]=\"selectedJob\"\r\n              [items]=\"jobsList\"\r\n              (onChangeSelected)=\"onSelectJob($event)\"\r\n              class=\"block w-full p-2\"\r\n            ></app-selection>\r\n          </div>\r\n        </div>\r\n        <!-- Hình thức làm việc -->\r\n        <div>\r\n          <label class=\"flex items-center gap-2\">\r\n            <input type=\"checkbox\" [(ngModel)]=\"filterWorkingType\" class=\"h-5 w-5\" />\r\n            Lọc theo hình thức làm việc\r\n          </label>\r\n          <div *ngIf=\"filterWorkingType\" class=\"mt-2\">\r\n            <select\r\n              [(ngModel)]=\"workingType\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-lg\"\r\n            >\r\n              <option [value]=\"null\" disabled>Chọn hình thức</option>\r\n              <option [value]=\"0\">Toàn thời gian</option>\r\n              <option [value]=\"1\">Bán thời gian</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <!-- Kinh nghiệm -->\r\n        <div>\r\n          <label class=\"flex items-center gap-2\">\r\n            <input type=\"checkbox\" [(ngModel)]=\"filterExperience\" class=\"h-5 w-5\" />\r\n            Lọc theo kinh nghiệm\r\n          </label>\r\n          <div *ngIf=\"filterExperience\" class=\"mt-2\">\r\n            <input\r\n              type=\"number\"\r\n              [(ngModel)]=\"requiredExperienceLevel\"\r\n              placeholder=\"Kinh nghiệm (năm)\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-lg\"\r\n            />\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Kết quả tìm kiếm -->\r\n    <div *ngIf=\"isLoading\" class=\"animate-pulse\">\r\n      <div class=\"h-20 bg-gray-200 rounded w-full mb-2\"></div>\r\n    </div>\r\n    <div *ngIf=\"!isLoading && searchResults.length > 0\" class=\"results-wrapper\">\r\n      <h2 class=\"text-xl font-bold mb-4\">Kết quả tìm kiếm ({{ totalCount }} việc làm)</h2>\r\n      <div *ngFor=\"let job of searchResults\" class=\"bg-white p-4 rounded-lg shadow-lg mb-4\">\r\n        <h3 class=\"text-lg font-semibold\">{{ job.name }}</h3>\r\n        <p class=\"text-gray-600\">{{ job.organizationName }} | {{ job.province }}</p>\r\n        <p class=\"text-gray-600\">Lương: {{ job.salary }} triệu</p>\r\n        <p class=\"text-gray-600\">Ngày hết hạn: {{ job.expdate | date:'dd/MM/yyyy' }}</p>\r\n        <button\r\n          class=\"mt-2 text-blue-500 hover:underline\"\r\n          (click)=\"onViewDetailItem(job)\"\r\n        >\r\n          Xem chi tiết\r\n        </button>\r\n      </div>\r\n      <!-- Phân trang -->\r\n      <div class=\"flex justify-center mt-4\">\r\n        <button\r\n          class=\"p-2 mx-1 border rounded-lg\"\r\n          (click)=\"changePage(page - 1)\"\r\n          [disabled]=\"page === 1\"\r\n        >\r\n          Trước\r\n        </button>\r\n        <span class=\"p-2 mx-1\">Trang {{ page }} / {{ totalPage }}</span>\r\n        <button\r\n          class=\"p-2 mx-1 border rounded-lg\"\r\n          (click)=\"changePage(page + 1)\"\r\n          [disabled]=\"page === totalPage\"\r\n        >\r\n          Sau\r\n        </button>\r\n      </div>\r\n    </div>\r\n    <div *ngIf=\"!isLoading && searchResults.length === 0\" class=\"text-center text-gray-500\">\r\n      Không tìm thấy kết quả phù hợp.\r\n    </div>\r\n  </div>\r\n</div>"
        }
    ]
}