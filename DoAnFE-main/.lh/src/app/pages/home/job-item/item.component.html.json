            "date": 1755659106713,
            "name": "Commit-0",
            "content": "<div class=\"relative rounded-lg border border-gray-200 bg-white hover:shadow cursor-pointer\" (click)=\"viewDetailItem()\">\r\n  <div class=\"absolute bottom-2 right-2 flex items-center gap-1\">\r\n    \r\n    <button type=\"button\"\r\n      class=\"w-8 h-8 flex items-center justify-center rounded-md bg-gray-50 border border-gray-200 hover:bg-gray-100\"\r\n      (click)=\"deleteItem($event)\" aria-label=\"Delete\">\r\n      <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"\r\n        class=\"w-5 h-5 text-gray-600\">\r\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 6h18\" />\r\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 6v-1a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v1\" />\r\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6\" />\r\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M10 11v6M14 11v6\" />\r\n      </svg>\r\n    </button>\r\n  </div>\r\n  <div class=\"p-4 flex items-start\">\r\n    <div\r\n  class=\"flex-shrink-0 w-16 h-16 rounded-md overflow-hidden bg-gray-50 border border-gray-200 flex items-center justify-center\">\r\n  <img class=\"max-h-12 max-w-12\" [src]=\"item.organizationAvatar || '../assets/icons/home.svg'\" alt=\"logo\" />\r\n</div>\r\n\r\n    <div class=\"ml-4 flex-1 min-w-0\">\r\n      <div class=\"text-base font-semibold text-gray-900 truncate\" [title]=\"item.name\">{{ item.name }}</div>\r\n      <div class=\"text-sm text-gray-600 truncate\" [title]=\"item.job\">{{ item.job }}</div>\r\n      <div class=\"text-xs text-gray-500 mt-1\">{{ item.district }}, {{ item.province }}</div>\r\n      <div class=\"mt-2 flex gap-2\">\r\n        <span *ngIf=\"item.workingType == 0 || item.workingType == null\"\r\n          class=\"text-xs bg-yellow-50 text-yellow-700 px-2 py-0.5 rounded\">{{ 'partTimeLbl' | translate }}</span>\r\n        <span *ngIf=\"item.workingType == 1\" class=\"text-xs bg-yellow-50 text-yellow-700 px-2 py-0.5 rounded\">{{\r\n          'fullTimeLbl' | translate }}</span>\r\n      </div>\r\n    </div>\r\n    <div class=\"ml-4 text-right\">\r\n      <div class=\"text-[var(--light-orange)] font-semibold\">\r\n        {{ formatSalary(item.salary) }} VNĐ\r\n      </div>\r\n      <div class=\"text-xs text-gray-500\">{{ item.expdate }}</div>\r\n    </div>\r\n  </div>\r\n</div>"
