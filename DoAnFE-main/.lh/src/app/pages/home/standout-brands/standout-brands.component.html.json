                    "date": 1764432625411,
                    "content": "Index: \n===================================================================\n--- \n+++ \n@@ -0,0 +1,68 @@\n+<div class=\"standout-brands-section\" *ngIf=\"!isLoading && organizations.length; else loading\">\r\n+  <div class=\"container\">\r\n+  <div class=\"banner\">\r\n+    <div class=\"banner-content\">\r\n+      <div class=\"banner-title\">Thương hiệu lớn tiêu biểu</div>\r\n+      <div class=\"banner-sub\">Hàng trăm thương hiệu lớn tiêu biểu đang tuyển dụng</div>\r\n+    </div>\r\n+    <button class=\"btn-pro\">Pro Company</button>\r\n+  </div>\r\n+  <div class=\"header\">\r\n+    <div class=\"categories\">\r\n+      <button *ngFor=\"let c of categories\" (click)=\"onSelectCategory(c)\" [class.active]=\"selectedCategory===c\">{{c}}</button>\r\n+    </div>\r\n+    <div class=\"header-nav\">\r\n+      <button class=\"circle-btn\" (click)=\"onPrev()\" aria-label=\"prev\">‹</button>\r\n+      <button class=\"circle-btn\" (click)=\"onNext()\" aria-label=\"next\">›</button>\r\n+    </div>\r\n+  </div>\r\n+  <div class=\"grid\">\r\n+    <div class=\"left-col\" *ngIf=\"organizations.length\">\r\n+      <div class=\"left-featured\">\r\n+        <div class=\"big-card\" (click)=\"onClickCompany(organizations[0])\">\r\n+        <div class=\"big-logo\"><img [src]=\"organizations[0].avatar\" [alt]=\"organizations[0].name\" /></div>\r\n+        <div class=\"big-title\">{{organizations[0].name}}</div>\r\n+        <div class=\"big-sub\">{{organizations[0].industry}}</div>\r\n+        <div class=\"big-stats\">\r\n+          <span class=\"count\"><i class=\"icon-briefcase\"></i> {{organizations[0].postCount}} việc làm</span>\r\n+        </div>\r\n+        <div class=\"big-actions\">\r\n+          <button class=\"btn-primary\">Pro Company</button>\r\n+          <button class=\"btn-outline\">+ Theo dõi</button>\r\n+        </div>\r\n+        </div>\r\n+      </div>\r\n+      <div class=\"left-bottom\" *ngIf=\"organizations.length > 1\">\r\n+        <div class=\"mini-card\" (click)=\"onClickCompany(organizations[1])\">\r\n+          <div class=\"mini-logo\"><img [src]=\"organizations[1].avatar\" [alt]=\"organizations[1].name\" /></div>\r\n+          <div class=\"mini-content\">\r\n+            <div class=\"mini-name\">{{organizations[1].name}}</div>\r\n+            <div class=\"mini-meta\">{{organizations[1].postCount}} việc làm</div>\r\n+          </div>\r\n+        </div>\r\n+      </div>\r\n+    </div>\r\n+    <div class=\"right-grid\">\r\n+      <div class=\"mini-card\" *ngFor=\"let org of organizations | slice:startIndexForRight:endIndexForRight\" (click)=\"onClickCompany(org)\">\r\n+        <div class=\"mini-logo\"><img [src]=\"org.avatar\" [alt]=\"org.name\" /></div>\r\n+        <div class=\"mini-content\">\r\n+          <div class=\"mini-name\">{{org.name}}</div>\r\n+          <div class=\"mini-meta\">{{org.postCount}} việc làm</div>\r\n+        </div>\r\n+      </div>\r\n+    </div>\r\n+    \r\n+    <!-- overlay arrows like reference -->\r\n+    <button class=\"overlay-btn overlay-left\" (click)=\"onPrev()\" aria-label=\"prev\">‹</button>\r\n+    <button class=\"overlay-btn overlay-right\" (click)=\"onNext()\" aria-label=\"next\">›</button>\r\n+  </div>\r\n+ \r\n+  </div>\r\n+</div>\r\n+<ng-template #loading>\r\n+  <div class=\"loading-skeleton\"></div>\r\n+  <div class=\"loading-skeleton\"></div>\r\n+  <div class=\"empty-hint\">Không có dữ liệu hiển thị</div>\r\n+</ng-template>\r\n+\r\n+\r\n"
                },
