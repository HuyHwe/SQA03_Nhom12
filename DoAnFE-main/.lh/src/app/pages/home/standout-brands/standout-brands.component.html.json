            "date": 1764432387616,
            "name": "Commit-0",
            "content": "<div class=\"standout-brands-section\">\r\n  <div class=\"grid\">\r\n    <div class=\"left-col\" *ngIf=\"organizations.length\">\r\n      <div class=\"big-card\" (click)=\"onClickCompany(organizations[0])\">\r\n        <img [src]=\"organizations[0].avatar\" [alt]=\"organizations[0].name\" />\r\n        <div>{{ organizations[0].name }}</div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"right-grid\">\r\n      <div class=\"mini-card\" *ngFor=\"let org of organizations | slice:startIndexForRight:endIndexForRight\"\r\n           (click)=\"onClickCompany(org)\">\r\n        <img [src]=\"org.avatar\" [alt]=\"org.name\" />\r\n        <div>{{ org.name }}</div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Chi tiết công ty + việc làm -->\r\n  <div *ngIf=\"selectedOrganizationDetail\">\r\n    <div class=\"company-detail\">\r\n      <h2>{{ selectedOrganizationDetail.organization.name }}</h2>\r\n      <img [src]=\"selectedOrganizationDetail.organization.avatar\" />\r\n      <p>{{ selectedOrganizationDetail.organization.description }}</p>\r\n      <p>Ngành: {{ selectedOrganizationDetail.organization.industry }}</p>\r\n      <p>Website: <a [href]=\"selectedOrganizationDetail.organization.website\" target=\"_blank\">{{ selectedOrganizationDetail.organization.website }}</a></p>\r\n    </div>\r\n\r\n    <div class=\"job-list\">\r\n      <h3>Danh sách việc làm</h3>\r\n      <div *ngFor=\"let job of selectedOrganizationDetail.jobs\" class=\"job-item\">\r\n        <h4>{{ job.job || job.name }}</h4>\r\n        <p>Địa chỉ: {{ job.address }}</p>\r\n        <p>Lương: {{ job.salary }}</p>\r\n        <p>Liên hệ: {{ job.phone }} - {{ job.email }}</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <div *ngIf=\"isDetailLoading\">\r\n    <p>Đang tải chi tiết công ty...</p>\r\n  </div>\r\n</div>\r\n"
        }
    ]
